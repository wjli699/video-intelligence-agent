# Copy to .env and adjust. Or export variables in your shell.
#
# Docker (docker-compose.yml): ingest uses MQTT_HOST=mosquitto and DATABASE_URL
# pointing at service `postgres` — set those in compose, not necessarily here.

# --- Postgres (event store) ---
DATABASE_URL=postgresql+psycopg2://postgres:eei@127.0.0.1:5432/postgres

# --- MQTT (ingest.py) ---
# Local broker: 127.0.0.1. Same compose stack: mosquitto
MQTT_HOST=127.0.0.1
MQTT_PORT=1883
MQTT_TOPIC=frigate/events

# --- Remote LLM (Local PC or Jetson: llama.cpp server, etc.) ---
LLM_BASE_URL=http://127.0.0.1:8000

# Create tables automatically (dev only)
INIT_DB_ON_STARTUP=0
INIT_DB_ON_INGEST_STARTUP=1
